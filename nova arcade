<!DOCTYPE html>
<html lang="ro">
<head>
<meta charset="UTF-8">
<title>NovaArcade</title>

<style>
body{
font-family:Arial;
background:#0f172a;
color:white;
text-align:center;
margin:0;
}

h1{
margin:20px;
}

.menu button{
margin:5px;
padding:10px 15px;
border:none;
border-radius:8px;
background:#38bdf8;
font-weight:bold;
cursor:pointer;
}

.container{
background:#1e293b;
margin:40px auto;
padding:20px;
border-radius:12px;
width:500px;
}

canvas{
background:black;
}

.grid{
display:grid;
grid-template-columns:repeat(3,1fr);
gap:5px;
}

.cell{
background:#334155;
padding:25px;
font-size:24px;
cursor:pointer;
}

.card{
display:inline-block;
width:60px;
height:60px;
background:#334155;
margin:5px;
font-size:28px;
line-height:60px;
cursor:pointer;
}
</style>
</head>

<body>

<h1>🎮 NovaArcade</h1>

<div class="menu">
<button onclick="scrollToGame('snake')">Snake</button>
<button onclick="scrollToGame('tic')">X și 0</button>
<button onclick="scrollToGame('memory')">Memory</button>
<button onclick="scrollToGame('dice')">Zar</button>
<button onclick="scrollToGame('coin')">Monedă</button>
</div>

<div class="container" id="snake">
<h2>🐍 Snake</h2>
<canvas id="snakeCanvas" width="400" height="400"></canvas>
<p>Folosește săgețile</p>
</div>

<div class="container" id="tic">
<h2>❌⭕ X și 0</h2>
<div class="grid" id="board"></div>
<p id="winner"></p>
</div>

<div class="container" id="memory">
<h2>🧠 Memory</h2>
<div id="memoryBoard"></div>
</div>

<div class="container" id="dice">
<h2>🎲 Zar</h2>
<button onclick="rollDice()">Aruncă</button>
<p id="diceResult"></p>
</div>

<div class="container" id="coin">
<h2>🪙 Monedă</h2>
<button onclick="coin()">Aruncă</button>
<p id="coinResult"></p>
</div>

<script>

// scroll
function scrollToGame(id){
document.getElementById(id).scrollIntoView({behavior:'smooth'})
}

// SNAKE
const canvas=document.getElementById("snakeCanvas")
const ctx=canvas.getContext("2d")

let snake=[{x:200,y:200}]
let food={x:100,y:100}
let dx=20
let dy=0

function draw(){
ctx.clearRect(0,0,400,400)

snake.forEach(p=>{
ctx.fillStyle="lime"
ctx.fillRect(p.x,p.y,20,20)
})

ctx.fillStyle="red"
ctx.fillRect(food.x,food.y,20,20)

let head={x:snake[0].x+dx,y:snake[0].y+dy}

if(head.x<0||head.x>=400||head.y<0||head.y>=400){
alert("Game Over")
snake=[{x:200,y:200}]
dx=20
dy=0
return
}

snake.unshift(head)

if(head.x===food.x&&head.y===food.y){
food.x=Math.floor(Math.random()*20)*20
food.y=Math.floor(Math.random()*20)*20
}else{
snake.pop()
}
}

setInterval(draw,120)

window.addEventListener("keydown",e=>{
if(e.key==="ArrowUp"){dx=0;dy=-20}
if(e.key==="ArrowDown"){dx=0;dy=20}
if(e.key==="ArrowLeft"){dx=-20;dy=0}
if(e.key==="ArrowRight"){dx=20;dy=0}
})

// TIC TAC TOE
const board=document.getElementById("board")
let cells=[]
let player="X"

for(let i=0;i<9;i++){
let c=document.createElement("div")
c.className="cell"
c.onclick=()=>play(i)
board.appendChild(c)
cells.push(c)
}

function play(i){
if(cells[i].innerText!=="")return

cells[i].innerText=player

checkWin()

player=player==="X"?"O":"X"
}

function checkWin(){
const w=[
[0,1,2],[3,4,5],[6,7,8],
[0,3,6],[1,4,7],[2,5,8],
[0,4,8],[2,4,6]
]

for(let combo of w){
let a=cells[combo[0]].innerText
let b=cells[combo[1]].innerText
let c=cells[combo[2]].innerText

if(a && a===b && a===c){
document.getElementById("winner").innerText="Câștigă "+a
}
}
}

// MEMORY
const icons=["🍎","🍌","🍇","🍒","🍎","🍌","🍇","🍒"]
icons.sort(()=>Math.random()-0.5)

const mem=document.getElementById("memoryBoard")
let opened=[]

icons.forEach(icon=>{
let card=document.createElement("div")
card.className="card"
card.innerText="?"
card.onclick=()=>flip(card,icon)
mem.appendChild(card)
})

function flip(card,icon){
if(opened.length===2 || card.innerText!=="?")return

card.innerText=icon
opened.push({card,icon})

if(opened.length===2){
setTimeout(()=>{
if(opened[0].icon!==opened[1].icon){
opened[0].card.innerText="?"
opened[1].card.innerText="?"
}
opened=[]
},700)
}
}

// DICE
function rollDice(){
let n=Math.floor(Math.random()*6)+1
document.getElementById("diceResult").innerText="Zar: "+n
}

// COIN
function coin(){
let r=Math.random()<0.5?"Cap":"Pajura"
document.getElementById("coinResult").innerText=r
}

</script>

</body>
</html>
